# Shared runtime
SERVER_NODE_ENV=development
SERVER_DEV_ACCESS_MODE=true
SERVER_PORT=8787
SOCKET_PORT=8282
DATABASE_URL=postgresql://user:password@localhost:5435/lighthouse_db?schema=public
SERVER_REDIS_URL=redis://localhost:6379
SOCKET_REDIS_URL=redis://localhost:6379

# Security
SERVER_JWT_SECRET=change-me
SOCKET_JWT_SECRET=change-me
SERVER_ADMIN_SECRET=change-me
SERVER_TURNSTILE_SERVER_KEY=
SERVER_CORS_ORIGINS=http://localhost:3000
SERVER_RELEASE_SHA=local

# AI providers
SERVER_OPENAI_API_KEY=
SERVER_OPENAI_PRIMARY_MODEL=gpt-4o-mini
SERVER_GEMINI_API_KEY=
SERVER_OPENROUTER_KEY=

# Object store
SERVER_OBJECT_STORE_MODE=local
SERVER_OBJECT_STORE_LOCAL_ROOT=.runtime/object_store
SERVER_AWS_ACCESS_KEY_ID=
SERVER_AWS_SECRET_ACCESS_KEY=
SERVER_AWS_REGION=
SERVER_AWS_BUCKET_NAME=
SERVER_CLOUDFRONT_DOMAIN=
SERVER_CLOUDFRONT_DOMAIN_TEMPLATES=
SERVER_CLOUDFRONT_DISTRIBUTION_ID=

# Payments
SERVER_RAZORPAY_KEY_ID=dummy
SERVER_RAZORPAY_KEY_SECRET=dummy
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Chains
SERVER_CHAIN_BASE_ENABLED=true
SERVER_CHAIN_SOLANA_ENABLED=true
SERVER_CRE_API_KEY=
SERVER_CRE_ETH_PRIVATE_KEY=
SERVER_BASE_DEPLOYER_PRIVATE_KEY=
SERVER_CRE_CLI_PATH=cre
SERVER_CRE_CLI_MIN_VERSION=1.2.0
SERVER_CRE_RUNNER_MODE=prebuilt
SERVER_CRE_PREBUILT_NODE_MODULES_PATH=/opt/lighthouse/cre-workflow/node_modules
SERVER_CRE_STARTUP_PRECHECK_REQUIRED=false
SERVER_CRE_SIMULATE_ONLY=false
SERVER_CRE_MIN_MAINNET_BALANCE_WEI=1
SERVER_CRE_WORKFLOW_OWNER_ADDRESS=
SERVER_ETHEREUM_MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com
SERVER_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
SERVER_BASE_MAINNET_RPC_URL=https://mainnet.base.org
COMPLIANCE_API_KEY=

# Frontend public URLs
NEXT_PUBLIC_BACKEND_URL=http://localhost:8787
NEXT_PUBLIC_SOCKET_URL=ws://localhost:8282

# Frontend internal server-to-server URL
INTERNAL_BACKEND_URL=http://localhost:8787

# Frontend flags
NEXT_PUBLIC_DEV_ACCESS_MODE=true
NEXT_PUBLIC_SKIP_AUTH=
NEXT_PUBLIC_SKIP_TEMPLATES_FETCH=
NEXT_PUBLIC_DEPLOY_PLACEHOLDER_MODE=true
NEXT_PUBLIC_CHAIN_BASE_ENABLED=true
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_BASE_MAINNET_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_ONCHAINKIT_API_KEY=

# Auth / wallet
NEXT_PUBLIC_DISABLE_PRIVY=false
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_JWKS_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Captcha
NEXT_PUBLIC_ENABLE_CAPTCHA=false
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
